# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.azurewebsites.net
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.azurewebsites.net
CSRF_TRUSTED_ORIGINS=https://your-backend.azurewebsites.net,https://your-frontend.azurewebsites.net

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/your_database?retryWrites=true&w=majority
MONGODB_NAME=your_database

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret
UNLOCK_AMOUNT_PAISE=1000
PLAN_WEEKLY_PAISE=1000
PLAN_WEEKLY_ORIGINAL_PAISE=10000
PLAN_MONTHLY_PAISE=4900
PLAN_MONTHLY_ORIGINAL_PAISE=4900
PLAN_YEARLY_PAISE=9900
PLAN_YEARLY_ORIGINAL_PAISE=99900

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
